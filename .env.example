# ── LLM Provider ──────────────────────────────────────────────────────────────
# "ollama" (local), "groq" (free hosted), or "bedrock"
LLM_PROVIDER=ollama

# ── Embeddings ────────────────────────────────────────────────────────────────
# "ollama" (local), "local" (sentence-transformers in-process, no service), or "bedrock"
EMBEDDING_PROVIDER=ollama
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Ollama (used when providers = ollama) ─────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Groq (used when LLM_PROVIDER=groq) — free key at https://console.groq.com ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS: comma-separated allowed origins, or * for any ───────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AWS Bedrock (used when LLM_PROVIDER=bedrock) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Overridden to http://qdrant:6333 inside Docker Compose automatically.
# Set this for running the backend outside Docker.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documind

# ── Retrieval ─────────────────────────────────────────────────────────────────
VECTOR_TOP_K=20
LEXICAL_TOP_K=20
RERANK_TOP_N=5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CONFIDENCE_THRESHOLD=0.1

# ── Ingestion ─────────────────────────────────────────────────────────────────
CHUNK_MAX_TOKENS=512
UPLOAD_DIR=uploads
SQLITE_PATH=data/documind.db
